@*
 * ForgotPassword.cshtml
 * Step 1 of the forgot password flow.
 * User enters their username — controller looks it up and redirects to ChooseMethod.
 *@

@* Disable shared layout — this page is fully standalone *@
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password — LuxeGroom</title>
    @* Favicon *@
    <link rel="icon" type="image/png" href="~/images/browsericon.png" />
    @* Google Fonts *@
    <link rel="stylesheet" href="~/css/fonts.css" />
    @* Forgot password shared styles *@
    <link rel="stylesheet" href="~/css/auth/forgotpassword.css" />
</head>
<body>
    @* Two-column layout — hero left, form right *@
    <div class="container">

        @* Left hero panel — hidden on small screens *@
        <div class="hero-section">
            <div class="hero-vignette"></div>
            <div class="hero-image"></div>
            @* Bottom-left hero text content *@
            <div class="hero-content">
                <div class="hero-badge">
                    <span class="hero-line"></span>
                    <span class="hero-badge-text">The Elite Standard</span>
                </div>
                <h2 class="hero-title">Precision. Grace. Distinction.</h2>
                <p class="hero-description">Experience the world's most exclusive grooming concierge for the discerning companion.</p>
            </div>
        </div>

        @* Right form panel *@
        <div class="form-section">
            <div class="form-wrapper">

                @* Back link to Login page *@
                <a asp-action="Index" asp-controller="Login" class="back-link">
                    <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
                    Back to Login
                </a>

                @* Step icon above the title *@
                <div class="step-icon">🔐</div>
                <h1 class="title">Forgot Password?</h1>
                <p class="subtitle">Enter your username and we'll help you reset your password.</p>

                @* Reserved error container — prevents layout shift *@
                <div class="error-container">
                    @* Show error message if one exists *@
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="error-message">@ViewBag.ErrorMessage</div>
                    }
                </div>

                @* Username submission form — posts to ForgotPasswordController *@
                <form asp-action="Index" asp-controller="ForgotPassword" method="post">
                    @* CSRF protection token *@
                    @Html.AntiForgeryToken()

                    @* Username input field with left person icon *@
                    <div class="form-group">
                        <label class="form-label">Username</label>
                        <div class="input-wrapper">
                            <input type="text" name="Username" class="form-input"
                                   placeholder="Enter your username" required />
                            <span class="material-symbols-outlined input-icon">person</span>
                        </div>
                    </div>

                    @* Submit button — proceeds to Step 2 *@
                    <button type="submit" class="submit-button">
                        Continue
                        <span class="material-symbols-outlined">arrow_right_alt</span>
                    </button>

                </form>

            </div>
        </div>
    </div>
</body>
</html>
