@*
 * ResetPassword.cshtml
 * Step 4 of the forgot password flow.
 * User enters and confirms their new password.
 * Includes live password strength checker same as AddUser form.
 *@

@* Disable shared layout — this page is fully standalone *@
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password — LuxeGroom</title>
    @* Favicon *@
    <link rel="icon" type="image/png" href="~/images/browsericon.png" />
    @* Google Fonts *@
    <link rel="stylesheet" href="~/css/fonts.css" />
    @* Forgot password shared styles *@
    <link rel="stylesheet" href="~/css/auth/forgotpassword.css" />
</head>
<body>
    @* Two-column layout — hero left, form right *@
    <div class="container">

        @* Left hero panel — hidden on small screens *@
        <div class="hero-section">
            <div class="hero-vignette"></div>
            <div class="hero-image"></div>
            @* Bottom-left hero text content *@
            <div class="hero-content">
                <div class="hero-badge">
                    <span class="hero-line"></span>
                    <span class="hero-badge-text">The Elite Standard</span>
                </div>
                <h2 class="hero-title">Precision. Grace. Distinction.</h2>
                <p class="hero-description">Experience the world's most exclusive grooming concierge for the discerning companion.</p>
            </div>
        </div>

        @* Right form panel *@
        <div class="form-section">
            <div class="form-wrapper">

                @* Step icon and title *@
                <div class="step-icon">🔑</div>
                <h1 class="title">Reset Password</h1>
                <p class="subtitle">Create a new strong password for your account.</p>

                @* Reserved error container — prevents layout shift *@
                <div class="error-container">
                    @* Show error message if one exists *@
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="error-message">@ViewBag.ErrorMessage</div>
                    }
                </div>

                @* Reset password form — posts to ResetPasswordController *@
                <form asp-action="Index" asp-controller="ResetPassword"
                      method="post" onsubmit="return validateReset()">
                    @* CSRF protection token *@
                    @Html.AntiForgeryToken()

                    @* Hidden field passing the verified username to the controller *@
                    <input type="hidden" name="Username" value="@ViewBag.Username" />

                    @* New password input with strength checker and toggle *@
                    <div class="form-group">
                        <label class="form-label">New Password</label>
                        <div class="input-wrapper">
                            <input type="password" name="Password" id="newPassword"
                                   class="form-input" placeholder="••••••••" required
                                   oninput="checkPasswordStrength(this.value)" />
                            <span class="material-symbols-outlined input-icon">lock</span>
                            @* Eye icon toggles new password visibility *@
                            <img src="~/images/show.png"
                                 class="password-toggle"
                                 onclick="togglePassword('newPassword', this)"
                                 alt="Toggle" />
                        </div>

                        @* Live password requirement indicators *@
                        <div class="password-requirements">
                            @* Minimum length requirement *@
                            <div class="requirement" id="req-length">
                                <span class="req-icon">✗</span>
                                <span>At least 8 characters</span>
                            </div>
                            @* Uppercase letter requirement *@
                            <div class="requirement" id="req-upper">
                                <span class="req-icon">✗</span>
                                <span>At least 1 uppercase letter</span>
                            </div>
                            @* Lowercase letter requirement *@
                            <div class="requirement" id="req-lower">
                                <span class="req-icon">✗</span>
                                <span>At least 1 lowercase letter</span>
                            </div>
                            @* Number requirement *@
                            <div class="requirement" id="req-number">
                                <span class="req-icon">✗</span>
                                <span>At least 1 number</span>
                            </div>
                            @* Special character requirement *@
                            <div class="requirement" id="req-special">
                                <span class="req-icon">✗</span>
                                <span>At least 1 special character (!@@#$...)</span>
                            </div>
                        </div>
                    </div>

                    @* Confirm password input with visibility toggle *@
                    <div class="form-group">
                        <label class="form-label">Confirm Password</label>
                        <div class="input-wrapper">
                            <input type="password" name="ConfirmPassword" id="confirmPassword"
                                   class="form-input" placeholder="••••••••" required />
                            <span class="material-symbols-outlined input-icon">lock</span>
                            @* Eye icon toggles confirm password visibility *@
                            <img src="~/images/show.png"
                                 class="password-toggle"
                                 onclick="togglePassword('confirmPassword', this)"
                                 alt="Toggle" />
                        </div>
                    </div>

                    @* Submit button — triggers validateReset() before posting *@
                    <button type="submit" class="submit-button">
                        Reset Password
                        <span class="material-symbols-outlined">arrow_right_alt</span>
                    </button>

                </form>

            </div>
        </div>
    </div>

    <script>
        // Toggle password input between text and password type
        function togglePassword(inputId, icon) {
            const input = document.getElementById(inputId);
            const isPassword = input.type === 'password';
            // Switch input type based on current state
            input.type = isPassword ? 'text' : 'password';
            // Swap eye icon between show and hide image
            icon.src = isPassword ? '/images/hide.png' : '/images/show.png';
        }

        // Update requirement indicators live as the user types
        function checkPasswordStrength(value) {
            setRequirement('req-length',  value.length >= 8);
            setRequirement('req-upper',   /[A-Z]/.test(value));
            setRequirement('req-lower',   /[a-z]/.test(value));
            setRequirement('req-number',  /[0-9]/.test(value));
            setRequirement('req-special', /[!@@#$%^&()\-_+={}|;':",./<>?\[\]\\]/.test(value));
        }

        // Apply passed or failed class and update the icon for a single requirement
        function setRequirement(id, passed) {
            const el = document.getElementById(id);
            const icon = el.querySelector('.req-icon');
            if (passed) {
                // Mark requirement as met — green checkmark
                el.classList.add('passed');
                el.classList.remove('failed');
                icon.textContent = '✓';
            } else {
                // Mark requirement as unmet — red cross
                el.classList.add('failed');
                el.classList.remove('passed');
                icon.textContent = '✗';
            }
        }

        // Validate all requirements and password match before form submission
        function validateReset() {
            const password = document.getElementById('newPassword').value;
            const confirm  = document.getElementById('confirmPassword').value;

            // Check all password strength rules
            const isValid =
                password.length >= 8 &&
                /[A-Z]/.test(password) &&
                /[a-z]/.test(password) &&
                /[0-9]/.test(password) &&
                /[!@@#$%^&()\-_+={}|;':",./<>?\[\]\\]/.test(password);

            // Block submission if password does not meet requirements
            if (!isValid) {
                document.getElementById('newPassword').focus();
                return false;
            }

            // Block submission if passwords do not match
            if (password !== confirm) {
                alert('Passwords do not match.');
                document.getElementById('confirmPassword').focus();
                return false;
            }

            // Allow form to submit
            return true;
        }
    </script>
</body>
</html>
