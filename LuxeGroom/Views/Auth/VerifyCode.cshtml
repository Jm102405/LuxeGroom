@*
 * VerifyCode.cshtml
 * Step 3 of the forgot password flow.
 * User enters the 6-digit OTP sent to their Gmail.
 * Auto-focuses next box on input and supports backspace navigation.
 *@

@* Disable shared layout — this page is fully standalone *@
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Code — LuxeGroom</title>
    @* Favicon *@
    <link rel="icon" type="image/png" href="~/images/browsericon.png" />
    @* Google Fonts *@
    <link rel="stylesheet" href="~/css/fonts.css" />
    @* Forgot password shared styles *@
    <link rel="stylesheet" href="~/css/auth/forgotpassword.css" />
</head>
<body>
    @* Two-column layout — hero left, form right *@
    <div class="container">

        @* Left hero panel — hidden on small screens *@
        <div class="hero-section">
            <div class="hero-vignette"></div>
            <div class="hero-image"></div>
            @* Bottom-left hero text content *@
            <div class="hero-content">
                <div class="hero-badge">
                    <span class="hero-line"></span>
                    <span class="hero-badge-text">The Elite Standard</span>
                </div>
                <h2 class="hero-title">Precision. Grace. Distinction.</h2>
                <p class="hero-description">Experience the world's most exclusive grooming concierge for the discerning companion.</p>
            </div>
        </div>

        @* Right form panel *@
        <div class="form-section">
            <div class="form-wrapper">

                @* Back link to Step 1 — ForgotPassword *@
                <a asp-action="Index" asp-controller="ForgotPassword" class="back-link">
                    <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
                    Back
                </a>

                @* Step icon and title *@
                <div class="step-icon">🔢</div>
                <h1 class="title">Enter Verify Code</h1>

                @* Subtitle showing the masked Gmail and expiry notice *@
                <p class="subtitle">
                    We sent a 6-digit code to <strong style="color: #f3f4f6;">@ViewBag.MaskedGmail</strong>.
                    It expires in 15 minutes.
                </p>

                @* Reserved error/success container — prevents layout shift *@
                <div class="error-container">
                    @* Show error message if OTP is invalid or expired *@
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="error-message">@ViewBag.ErrorMessage</div>
                    }
                    @* Show success message if code was resent *@
                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="success-message">@ViewBag.SuccessMessage</div>
                    }
                </div>

                @* OTP form — posts to VerifyCodeController *@
                <form asp-action="Index" asp-controller="VerifyCode" method="post">
                    @* CSRF protection token *@
                    @Html.AntiForgeryToken()

                    @* Hidden field passing the username to the controller *@
                    <input type="hidden" name="Username" value="@ViewBag.Username" />

                    @* Six individual OTP digit input boxes *@
                    <div class="otp-container">
                        <input class="otp-input" type="text" maxlength="1" inputmode="numeric" />
                        <input class="otp-input" type="text" maxlength="1" inputmode="numeric" />
                        <input class="otp-input" type="text" maxlength="1" inputmode="numeric" />
                        <input class="otp-input" type="text" maxlength="1" inputmode="numeric" />
                        <input class="otp-input" type="text" maxlength="1" inputmode="numeric" />
                        <input class="otp-input" type="text" maxlength="1" inputmode="numeric" />
                    </div>

                    @* Hidden field that receives the combined 6-digit code before submit *@
                    <input type="hidden" name="Code" id="otpValue" />

                    @* Submit button — combines OTP boxes before posting *@
                    <button type="submit" class="submit-button" onclick="return combineOtp()">
                        Verify Code
                        <span class="material-symbols-outlined">arrow_right_alt</span>
                    </button>

                </form>

                @* Resend code link — re-triggers SendCode with the same username *@
                <div class="resend-section">
                    Didn't receive the code?
                    <a asp-action="Index"
                       asp-controller="SendCode"
                       asp-route-username="@ViewBag.Username"
                       asp-route-method="gmail"
                       class="resend-link">Resend Code</a>
                </div>

            </div>
        </div>
    </div>

    <script>
        // Select all 6 OTP digit input boxes
        const inputs = document.querySelectorAll('.otp-input');

        inputs.forEach((input, index) => {
            // Auto-focus the next box when a digit is entered
            input.addEventListener('input', () => {
                if (input.value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });

            // Move focus back to the previous box on backspace if current box is empty
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && input.value === '' && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });

        // Combine all 6 digit boxes into the hidden Code field before submit
        function combineOtp() {
            const code = Array.from(inputs).map(i => i.value).join('');
            // Block submission if not all 6 digits are filled
            if (code.length < 6) {
                alert('Please enter the complete 6-digit code.');
                return false;
            }
            // Set the combined code into the hidden input
            document.getElementById('otpValue').value = code;
            return true;
        }
    </script>
</body>
</html>
