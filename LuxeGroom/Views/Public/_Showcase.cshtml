    @*
 * _Showcase.cshtml
 * Gallery / Service Showcase section with three groups.
 *@

<section class="showcase" id="gallery">
    <div class="container">

        <div class="showcase-header">
            <span class="showcase-eyebrow">Visual Excellence</span>
            <h2>Service Showcase</h2>
            <div class="showcase-divider"></div>
        </div>

        <!-- Bath & Brush -->
        <div class="showcase-group">
            <div class="showcase-group-header">
                <h3><em>Bath &amp; Brush</em></h3>
                <div class="showcase-group-line"></div>
            </div>
            <div class="showcase-grid showcase-grid--portrait">
                <div class="showcase-item">
                    <img src="@Url.Content("~/images/cocoshine.png")" alt="Clean shiny dog in spa setting" />
                    <div class="showcase-overlay"></div>
                </div>
                <div class="showcase-item">
                    <img src="@Url.Content("~/images/leowellbrushed.png")" alt="Well brushed companion" />
                    <div class="showcase-overlay"></div>
                </div>
                <div class="showcase-item">
                    <img src="@Url.Content("~/images/cocopris.png")" alt="Pristine grooming results" />
                    <div class="showcase-overlay"></div>
                </div>
            </div>
        </div>

        <!-- Full Groom -->
        <div class="showcase-group">
            <div class="showcase-group-header">
                <h3><em>Full Groom</em></h3>
                <div class="showcase-group-line"></div>
            </div>
            <div class="showcase-grid showcase-grid--landscape">
                <div class="showcase-item showcase-item--overlay">
                    <img src="@Url.Content("~/images/cocofullgroom.png")" alt="Full groom result 1" />
                    <div class="showcase-overlay"></div>
                </div>
                <div class="showcase-item showcase-item--overlay">
                    <img src="@Url.Content("~/images/leofullgroom.png")" alt="Full groom result 2" />
                    <div class="showcase-overlay"></div>
                </div>
            </div>
        </div>

        <!-- Custom Cut -->
        <div class="showcase-group">
            <div class="showcase-group-header">
                <h3><em>Custom Cut</em></h3>
                <div class="showcase-group-line"></div>
            </div>
            <div class="showcase-grid showcase-grid--square">
                <div class="showcase-item showcase-item--bordered">
                    <img src="@Url.Content("~/images/leoteddycut.png")" alt="Teddy Cut style" />
                    <div class="showcase-overlay"></div>
                </div>
                <div class="showcase-item showcase-item--bordered">
                    <img src="@Url.Content("~/images/cocopuppycut.png")" alt="Puppy Cut style" />
                    <div class="showcase-overlay"></div>
                </div>
                <div class="showcase-item showcase-item--bordered">
                    <img src="@Url.Content("~/images/leocustomcut.png")" alt="Bespoke creative styling" />
                    <div class="showcase-overlay"></div>
                </div>
            </div>
        </div>

    </div>
</section>
