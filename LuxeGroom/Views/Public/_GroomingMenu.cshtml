@*
 * _GroomingMenu.cshtml
 * Services / Grooming Menu section with three pricing cards.
 *@

<section class="grooming-menu" id="services">
    <div class="container">
        <div class="section-header">
            <h2>Grooming Menu</h2>
            <div class="gold-divider"></div>
        </div>
        <div class="menu-grid">

            <!-- Card 1: Bath & Brush -->
            <div class="menu-card">
                <div class="menu-card-body">
                    <h3>Bath &amp; Brush</h3>
                    <p>Includes bath, blow-dry, brush, ear cleaning &amp; nail trim.</p>
                    <div class="menu-prices">
                        <div class="price-row">
                            <span class="price-size">SMALL DOG</span>
                            <span class="price-value">₱300</span>
                        </div>
                        <div class="price-row">
                            <span class="price-size">MEDIUM DOG</span>
                            <span class="price-value">₱600</span>
                        </div>
                        <div class="price-row">
                            <span class="price-size">LARGE DOG</span>
                            <span class="price-value">₱750</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 2: Full Groom (Featured) -->
            <div class="menu-card menu-card--featured">
                <div class="menu-badge">Most Requested</div>
                <div class="menu-card-body">
                    <h3>Full Groom</h3>
                    <p>Full haircut + bath + nails + ears. Our signature standard of excellence.</p>
                    <div class="menu-prices">
                        <div class="price-row">
                            <span class="price-size">SMALL DOG</span>
                            <span class="price-value">₱900</span>
                        </div>
                        <div class="price-row">
                            <span class="price-size">MEDIUM DOG</span>
                            <span class="price-value">₱1,000</span>
                        </div>
                        <div class="price-row">
                            <span class="price-size">LARGE DOG</span>
                            <span class="price-value">₱1,250</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 3: Custom Cut -->
            <div class="menu-card">
                <div class="menu-card-body">
                    <h3>Custom Cut</h3>
                    <p>Teddy cut, Puppy Cut, and bespoke styling tailored to your companion's features.</p>
                    <div class="menu-prices">
                        <div class="price-row">
                            <span class="price-size">SMALL DOG</span>
                            <span class="price-value">₱1,200</span>
                        </div>
                        <div class="price-row">
                            <span class="price-size">MEDIUM DOG</span>
                            <span class="price-value">₱1,300</span>
                        </div>
                        <div class="price-row">
                            <span class="price-size">LARGE DOG</span>
                            <span class="price-value">₱1,500</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
