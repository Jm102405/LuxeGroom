@*
 * _Chatbot.cshtml
 * Floating chat widget for the LuxeGroom public landing page.
 * Included as a partial in LandingPage.cshtml.
 *
 * Features:
 *   - Floating launcher button (lower-right corner)
 *   - Chat panel covering ~1/4 of the screen
 *   - Two header buttons: 'Instructions' and 'Data'
 *     → Each opens a modal showing its content from the [Chatbot] table
 *   - Chat input: user types a question, OpenAI (gpt-4) responds
 *     using Instructions + Data from the DB as system context
 *   - Conversation history maintained client-side per session
 *
 * API endpoint: POST /Chatbot/Ask  (defined in ChatbotController.cs)
 *@

<!-- ═══════════════════════════════════════════════
     FLOATING LAUNCHER BUTTON
════════════════════════════════════════════════ -->
<button id="lg-chat-launcher" class="lg-chat-launcher" aria-label="Open chat" title="Chat with us">
    <span class="lg-launcher-icon lg-icon-open">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 2H4C2.9 2 2 2.9 2 4V22L6 18H20C21.1 18 22 17.1 22 16V4C22 2.9 21.1 2 20 2Z" fill="currentColor"/>
            <circle cx="8"  cy="11" r="1.2" fill="white"/>
            <circle cx="12" cy="11" r="1.2" fill="white"/>
            <circle cx="16" cy="11" r="1.2" fill="white"/>
        </svg>
    </span>
    <span class="lg-launcher-icon lg-icon-close" style="display:none;">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
    </span>
</button>

<!-- ═══════════════════════════════════════════════
     CHAT PANEL
════════════════════════════════════════════════ -->
<div id="lg-chat-panel" class="lg-chat-panel" aria-hidden="true" role="dialog" aria-label="Luxe Groom Chat">

    <!-- Header -->
    <div class="lg-chat-header">
        <div class="lg-header-brand">
            <div class="lg-avatar">✦</div>
            <div>
                <div class="lg-header-title">Luxe Groom</div>
                <div class="lg-header-status">AI Assistant · Online</div>
            </div>
        </div>

        <!-- Instructions & Data viewer buttons -->
        <div class="lg-header-buttons">
            <button class="lg-ctx-btn" id="lg-btn-instructions" title="View Instructions from database">
                Instructions
            </button>
            <button class="lg-ctx-btn" id="lg-btn-data" title="View Data from database">
                Data
            </button>
            <button class="lg-icon-btn" id="lg-close-btn" aria-label="Close chat">
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16">
                    <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- Messages -->
    <div class="lg-messages" id="lg-messages" role="log" aria-live="polite">
        <div class="lg-msg-group lg-assistant-group">
            <div class="lg-msg lg-assistant-msg">
                <p>👋 Hello! I'm the Luxe Groom AI assistant. How can I help you today?</p>
            </div>
            <div class="lg-msg-meta">Just now</div>
        </div>
    </div>

    <!-- Typing indicator -->
    <div class="lg-typing" id="lg-typing" style="display:none;">
        <span></span><span></span><span></span>
        <span class="lg-typing-text">Thinking…</span>
    </div>

    <!-- Input area -->
    <div class="lg-input-area">
        <div class="lg-input-wrapper">
            <textarea
                id="lg-input"
                class="lg-input"
                placeholder="Ask me anything…"
                rows="1"
                maxlength="1000"
                aria-label="Chat message"></textarea>
            <button id="lg-send-btn" class="lg-send-btn" aria-label="Send">
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16">
                    <path d="M22 2L11 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M22 2L15 22L11 13L2 9L22 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>
        </div>
        <div class="lg-input-footer">Powered by GPT-4</div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════
     INSTRUCTIONS MODAL
════════════════════════════════════════════════ -->
<div class="lg-modal-overlay" id="lg-instructions-modal" style="display:none;" role="dialog" aria-label="Instructions">
    <div class="lg-modal-box">
        <div class="lg-modal-header">
            <h3 class="lg-modal-title">Instructions</h3>
            <button class="lg-icon-btn" onclick="lgCloseModal('lg-instructions-modal')" aria-label="Close">
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16">
                    <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
            </button>
        </div>
        <div class="lg-modal-body">
            <p id="lg-instructions-content" class="lg-modal-content">Loading…</p>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════
     DATA MODAL
════════════════════════════════════════════════ -->
<div class="lg-modal-overlay" id="lg-data-modal" style="display:none;" role="dialog" aria-label="Data">
    <div class="lg-modal-box">
        <div class="lg-modal-header">
            <h3 class="lg-modal-title">Data</h3>
            <button class="lg-icon-btn" onclick="lgCloseModal('lg-data-modal')" aria-label="Close">
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16">
                    <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
            </button>
        </div>
        <div class="lg-modal-body">
            <p id="lg-data-content" class="lg-modal-content">Loading…</p>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════
     STYLES  (scoped with lg- prefix to avoid conflicts)
════════════════════════════════════════════════ -->
<style>
    /* Launcher */
    .lg-chat-launcher {
        position: fixed; bottom: 1.75rem; right: 1.75rem; z-index: 9000;
        width: 58px; height: 58px; border-radius: 50%;
        background: linear-gradient(135deg, #c9a84c, #a67c32);
        border: none; cursor: pointer; display: flex;
        align-items: center; justify-content: center;
        box-shadow: 0 8px 28px rgba(201,168,76,0.45);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        color: white;
    }
    .lg-chat-launcher:hover {
        transform: scale(1.08);
        box-shadow: 0 12px 36px rgba(201,168,76,0.6);
    }
    .lg-launcher-icon { width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; }
    .lg-launcher-icon svg { width: 100%; height: 100%; }

    /* Chat panel */
    .lg-chat-panel {
        position: fixed;
        bottom: calc(1.75rem + 58px + 0.75rem);
        right: 1.75rem;
        z-index: 8999;
        width: min(400px, calc(100vw - 2rem));
        height: min(560px, calc(100vh - 160px));
        background: #111827;
        border: 1px solid rgba(201,168,76,0.2);
        border-radius: 16px;
        box-shadow: 0 24px 64px rgba(0,0,0,0.7);
        display: flex; flex-direction: column; overflow: hidden;
        /* Hidden by default */
        opacity: 0; transform: translateY(20px) scale(0.96);
        pointer-events: none;
        transition: opacity 0.3s ease, transform 0.3s ease;
        transform-origin: bottom right;
    }
    .lg-chat-panel.lg-open {
        opacity: 1; transform: translateY(0) scale(1);
        pointer-events: all;
    }

    /* Header */
    .lg-chat-header {
        background: #0f111a;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        padding: 0.85rem 1rem;
        display: flex; align-items: center;
        justify-content: space-between; flex-shrink: 0; gap: 0.5rem;
    }
    .lg-header-brand { display: flex; align-items: center; gap: 0.65rem; }
    .lg-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        background: linear-gradient(135deg, #c9a84c, #a67c32);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem; color: white; font-weight: 700; flex-shrink: 0;
    }
    .lg-header-title  { font-size: 0.88rem; font-weight: 700; color: #e5e7eb; }
    .lg-header-status { font-size: 0.7rem;  color: #c9a84c; font-weight: 500; }

    .lg-header-buttons { display: flex; align-items: center; gap: 0.4rem; }

    /* Instructions / Data buttons */
    .lg-ctx-btn {
        background: rgba(201,168,76,0.1);
        border: 1px solid rgba(201,168,76,0.3);
        color: #c9a84c; border-radius: 6px;
        padding: 0.3rem 0.65rem; font-size: 0.7rem; font-weight: 600;
        cursor: pointer; transition: all 0.2s; white-space: nowrap;
    }
    .lg-ctx-btn:hover { background: #c9a84c; color: #0f111a; }

    /* Icon-only button (close) */
    .lg-icon-btn {
        width: 28px; height: 28px; border-radius: 6px; border: none;
        background: transparent; color: #6b7280; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s;
    }
    .lg-icon-btn:hover { background: rgba(255,255,255,0.08); color: #e5e7eb; }

    /* Messages */
    .lg-messages {
        flex: 1; overflow-y: auto; padding: 1rem;
        display: flex; flex-direction: column; gap: 0.85rem;
        scroll-behavior: smooth;
    }
    .lg-messages::-webkit-scrollbar { width: 4px; }
    .lg-messages::-webkit-scrollbar-thumb { background: #374151; border-radius: 4px; }

    .lg-msg-group { display: flex; flex-direction: column; gap: 0.2rem; animation: lgFadeUp 0.3s ease; }
    .lg-assistant-group { align-items: flex-start; }
    .lg-user-group      { align-items: flex-end; }

    @@keyframes lgFadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .lg-msg {
        max-width: 85%; padding: 0.6rem 0.95rem;
        border-radius: 14px; font-size: 0.86rem; line-height: 1.6;
        word-wrap: break-word;
    }
    .lg-msg p:not(:last-child) { margin-bottom: 0.4rem; }

    .lg-assistant-msg {
        background: #1f2937; border: 1px solid rgba(255,255,255,0.07);
        color: #e5e7eb; border-bottom-left-radius: 4px;
    }
    .lg-user-msg {
        background: linear-gradient(135deg, #c9a84c, #a67c32);
        color: white; border-bottom-right-radius: 4px;
    }
    .lg-error-msg {
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.3); color: #fca5a5;
    }
    .lg-msg-meta { font-size: 0.68rem; color: #4b5563; padding: 0 0.2rem; }

    /* Typing indicator */
    .lg-typing {
        display: flex; align-items: center; gap: 5px;
        padding: 0.4rem 1rem; flex-shrink: 0;
    }
    .lg-typing span {
        width: 7px; height: 7px; background: #4b5563;
        border-radius: 50%; animation: lgBounce 1.2s infinite;
    }
    .lg-typing span:nth-child(2) { animation-delay: 0.2s; }
    .lg-typing span:nth-child(3) { animation-delay: 0.4s; }
    .lg-typing-text {
        width: auto !important; height: auto !important;
        background: none !important; border-radius: 0 !important;
        animation: none !important; font-size: 0.72rem;
        color: #6b7280; font-style: italic; margin-left: 0.25rem;
    }
    @@keyframes lgBounce {
        0%, 60%, 100% { transform: translateY(0); }
        30%            { transform: translateY(-5px); }
    }

    /* Input area */
    .lg-input-area {
        padding: 0.75rem; border-top: 1px solid rgba(255,255,255,0.07);
        background: #0f111a; flex-shrink: 0;
    }
    .lg-input-wrapper {
        display: flex; align-items: flex-end; gap: 0.5rem;
        background: #1f2937; border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px; padding: 0.5rem 0.5rem 0.5rem 0.85rem;
        transition: border-color 0.2s;
    }
    .lg-input-wrapper:focus-within { border-color: rgba(201,168,76,0.4); }

    .lg-input {
        flex: 1; background: transparent; border: none; outline: none;
        color: #e5e7eb; font-size: 0.86rem; line-height: 1.5;
        resize: none; max-height: 100px; overflow-y: auto;
        font-family: 'Manrope', sans-serif;
    }
    .lg-input::placeholder { color: #4b5563; }

    .lg-send-btn {
        width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
        background: linear-gradient(135deg, #c9a84c, #a67c32);
        border: none; color: white; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s;
    }
    .lg-send-btn:hover   { transform: scale(1.05); }
    .lg-send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .lg-input-footer {
        font-size: 0.67rem; color: #374151; text-align: center;
        padding-top: 0.35rem;
    }

    /* Modals */
    .lg-modal-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,0.7);
        backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        z-index: 9100;
    }
    .lg-modal-box {
        background: #111827; border: 1px solid rgba(201,168,76,0.25);
        border-radius: 14px; padding: 28px;
        width: min(480px, calc(100vw - 2rem));
        box-shadow: 0 20px 60px rgba(0,0,0,0.6);
        animation: lgFadeUp 0.2s ease;
    }
    .lg-modal-header {
        display: flex; justify-content: space-between;
        align-items: center; margin-bottom: 16px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .lg-modal-title { font-size: 1rem; font-weight: 700; color: #c9a84c; margin: 0; }
    .lg-modal-body  { max-height: 300px; overflow-y: auto; }
    .lg-modal-content {
        font-size: 0.88rem; color: #d1d5db; line-height: 1.7;
        white-space: pre-wrap; margin: 0;
    }
</style>

<!-- ═══════════════════════════════════════════════
     SCRIPT
════════════════════════════════════════════════ -->
<script>
(function () {
    'use strict';

    // ── DOM refs ───────────────────────────────────────────────
    const launcher   = document.getElementById('lg-chat-launcher');
    const panel      = document.getElementById('lg-chat-panel');
    const messagesEl = document.getElementById('lg-messages');
    const inputEl    = document.getElementById('lg-input');
    const sendBtn    = document.getElementById('lg-send-btn');
    const closeBtn   = document.getElementById('lg-close-btn');
    const typingEl   = document.getElementById('lg-typing');
    const openIcon   = launcher.querySelector('.lg-icon-open');
    const closeIcon  = launcher.querySelector('.lg-icon-close');

    // ── State ──────────────────────────────────────────────────
    let isOpen       = false;
    let isLoading    = false;
    let conversation = []; // [{ role, content }]

    // ── Open / close panel ─────────────────────────────────────
    function openChat() {
        isOpen = true;
        panel.classList.add('lg-open');
        panel.setAttribute('aria-hidden', 'false');
        openIcon.style.display  = 'none';
        closeIcon.style.display = 'flex';
        inputEl.focus();
    }

    function closeChat() {
        isOpen = false;
        panel.classList.remove('lg-open');
        panel.setAttribute('aria-hidden', 'true');
        openIcon.style.display  = 'flex';
        closeIcon.style.display = 'none';
    }

    launcher.addEventListener('click', () => isOpen ? closeChat() : openChat());
    closeBtn.addEventListener('click', closeChat);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeChat(); lgCloseAllModals(); } });

    // ── Instructions / Data modals ─────────────────────────────
    document.getElementById('lg-btn-instructions').addEventListener('click', async () => {
        await lgOpenContextModal('instructions');
    });

    document.getElementById('lg-btn-data').addEventListener('click', async () => {
        await lgOpenContextModal('data');
    });

async function lgOpenContextModal(type) {
    const modalId = type === 'instructions' ? 'lg-instructions-modal' : 'lg-data-modal';
    const contentId = type === 'instructions' ? 'lg-instructions-content' : 'lg-data-content';
    const modal = document.getElementById(modalId);
    const contentEl = document.getElementById(contentId);

    contentEl.textContent = 'Loading…';
    modal.style.display = 'flex';

    try {
        const res = await fetch('/AIChatbot/Context');
        if (!res.ok) {
            throw new Error(`HTTP ${res.status}: ${res.statusText}`);
        }
        const json = await res.json();
        
        contentEl.textContent = type === 'instructions'
            ? (json.instructions || 'No instructions found.')
            : (json.data || 'No data found.');
    } catch (err) {
        console.error('Modal load error:', err);
        contentEl.textContent = `Failed: ${err.message}. Check console.`;
    }
}

    // Close modal helpers (called from inline onclick in HTML above)
    window.lgCloseModal = function (id) {
        document.getElementById(id).style.display = 'none';
    };

    function lgCloseAllModals() {
        document.getElementById('lg-instructions-modal').style.display = 'none';
        document.getElementById('lg-data-modal').style.display = 'none';
    }

    // Close modals on overlay click
    ['lg-instructions-modal', 'lg-data-modal'].forEach(id => {
        document.getElementById(id).addEventListener('click', function (e) {
            if (e.target === this) lgCloseModal(id);
        });
    });

    // ── Auto-resize textarea ───────────────────────────────────
    inputEl.addEventListener('input', () => {
        inputEl.style.height = 'auto';
        inputEl.style.height = Math.min(inputEl.scrollHeight, 100) + 'px';
    });

    // ── Send on Enter (Shift+Enter = newline) ──────────────────
    inputEl.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            if (!isLoading) sendMessage();
        }
    });

    sendBtn.addEventListener('click', () => { if (!isLoading) sendMessage(); });

    // ── Helpers ────────────────────────────────────────────────
    function getTime() {
        return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function scrollToBottom() {
        messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function appendMessage(role, text, isError = false) {
        const group = document.createElement('div');
        group.className = `lg-msg-group ${role === 'user' ? 'lg-user-group' : 'lg-assistant-group'}`;

        const msg = document.createElement('div');
        msg.className = 'lg-msg ' + (role === 'user'
            ? 'lg-user-msg'
            : isError ? 'lg-assistant-msg lg-error-msg' : 'lg-assistant-msg');

        const lines = text.split('\n').filter(l => l.trim());
        msg.innerHTML = lines.length > 1
            ? lines.map(l => `<p>${escHtml(l)}</p>`).join('')
            : `<p>${escHtml(text)}</p>`;

        const meta = document.createElement('div');
        meta.className   = 'lg-msg-meta';
        meta.textContent = getTime();

        group.appendChild(msg);
        group.appendChild(meta);
        messagesEl.appendChild(group);
        scrollToBottom();
    }

    function escHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;')
                .replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }

    function setLoading(v) {
        isLoading = v;
        sendBtn.disabled = v;
        inputEl.disabled = v;
        typingEl.style.display = v ? 'flex' : 'none';
        if (v) scrollToBottom();
    }

    // ── Send message to /Chatbot/Ask ───────────────────────────
    async function sendMessage() {
        const text = inputEl.value.trim();
        if (!text || isLoading) return;

        conversation.push({ role: 'user', content: text });
        appendMessage('user', text);

        inputEl.value       = '';
        inputEl.style.height = 'auto';
        setLoading(true);

        try {
            const res = await fetch('/AIChatbot/Ask', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ messages: conversation })
            });

            if (!res.ok) throw new Error(`HTTP ${res.status}`);

            const data = await res.json();

            if (data.success) {
                conversation.push({ role: 'assistant', content: data.message });
                appendMessage('assistant', data.message);
            } else {
                appendMessage('assistant', ' ' + (data.error || 'Something went wrong.'), true);
            }
        } catch (err) {
            appendMessage('assistant', 'Could not reach the server. Please try again.', true);
        } finally {
            setLoading(false);
            inputEl.focus();
        }
    }

})();
</script>
