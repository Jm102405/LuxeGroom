@*
 * _ReservationModal.cshtml
 * Reservation modal overlay with form.
 * Shows a luxury success message after submission.
 * Updated in Thread 3.7: Added Pet Size dropdown.
 * Updated in Thread 3.7: checkEmailExists now shows role-based error message.
 * Updated in Thread 4.3.1: Phone number restricted to valid PH format.
 * Updated in Thread 4.3.1: Date restricted to 1–2 days from today only.
 * Updated in Thread 4.3.2: Fixed date timezone offset — now uses local browser date (not UTC).
 * Updated in Thread 4.3.3: Added checkOwnerNameExists() — blocks name matching a system Username.
 *@

@* ===== SUCCESS OVERLAY ===== *@
<div class="success-overlay" id="successOverlay">
    <div class="success-panel">
        <div class="success-icon">
            <span class="material-symbols-outlined">check_circle</span>
        </div>
        <h2 class="success-title">Reservation Submitted</h2>
        <p class="success-message">
            Thank you for choosing LuxeGroom. Your reservation has been received and is currently under review. Our concierge team will be in touch shortly.
        </p>
        <button class="btn-success-close" onclick="closeSuccess()">Close</button>
    </div>
</div>

@* ===== RESERVATION MODAL ===== *@
<div class="modal-overlay" id="reservationModal">
    <div class="modal-panel">

        <div class="modal-icon">
            <span class="material-symbols-outlined">calendar_month</span>
        </div>

        <h2 class="modal-title">Reservation Form</h2>

        <form id="reservationForm" class="modal-form" action="/Reservation/Create" method="post"
              onsubmit="handleReservationSubmit(event)">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">OWNER'S NAME</label>
                <input type="text"
                       name="OwnerName"
                       id="reservationOwnerName"
                       class="form-input"
                       required
                       onblur="checkOwnerNameExists()" />
                <p id="ownerNameError" style="color:#ef4444;font-size:12px;margin-top:4px;display:none;"></p>
            </div>

            <div class="form-group">
                <label class="form-label">PET'S NAME</label>
                <input type="text" name="PetName" class="form-input" required />
            </div>

            <div class="form-group">
                <label class="form-label">PET SIZE</label>
                <div class="form-select-wrapper">
                    <select name="PetSize" class="form-input form-select" required>
                        <option value="" disabled selected hidden></option>
                        <option value="Small Dog">Small Dog</option>
                        <option value="Medium Dog">Medium Dog</option>
                        <option value="Large Dog">Large Dog</option>
                    </select>
                    <span class="form-select-arrow material-symbols-outlined">expand_more</span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">GROOMING STYLE</label>
                <div class="form-select-wrapper">
                    <select name="GroomingStyle" class="form-input form-select" required>
                        <option value="" disabled selected hidden></option>
                        <option value="Bath & Brush">Bath &amp; Brush</option>
                        <option value="Full Groom">Full Groom</option>
                        <option value="Custom Cut">Custom Cut</option>
                    </select>
                    <span class="form-select-arrow material-symbols-outlined">expand_more</span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">PHONE NUMBER</label>
                <div class="form-input-icon-wrapper">
                    <input type="tel"
                           name="PhoneNumber"
                           id="reservationPhone"
                           class="form-input form-input--icon"
                           placeholder="09XXXXXXXXX"
                           maxlength="11"
                           required
                           oninput="validatePhone(this)"
                           onblur="validatePhone(this)" />
                    <span class="form-input-icon material-symbols-outlined">call</span>
                </div>
                <p id="phoneError" style="color:#ef4444;font-size:12px;margin-top:4px;display:none;"></p>
            </div>

            <div class="form-group">
                <label class="form-label">EMAIL ADDRESS</label>
                <div class="form-input-icon-wrapper">
                    <input type="email"
                           name="Email"
                           id="reservationEmail"
                           class="form-input form-input--icon"
                           placeholder="yourname@email.com"
                           required
                           onblur="checkEmailExists()" />
                    <span class="form-input-icon material-symbols-outlined">mail</span>
                </div>
                <p id="emailError" style="color:#ef4444;font-size:12px;margin-top:4px;display:none;"></p>
            </div>

            <div class="form-group">
                <label class="form-label">RESERVATION DATE</label>
                <input type="date"
                       name="ReservationDate"
                       id="reservationDate"
                       class="form-input"
                       required
                       onchange="validateDate(this)" />
                <p id="dateError" style="color:#ef4444;font-size:12px;margin-top:4px;display:none;"></p>
            </div>

            <div class="modal-actions">
                <button type="submit" class="btn-modal-confirm" id="submitBtn">Confirm Reservation</button>
                <button type="button" class="btn-modal-cancel" onclick="closeModal()">Cancel</button>
            </div>

        </form>
    </div>
</div>

<script>
    // ===== PHONE VALIDATION =====
    // Accepts: 09XXXXXXXXX (11 digits, starts with 09)
    function validatePhone(input) {
        const phoneError = document.getElementById('phoneError');
        const value = input.value.replace(/\D/g, '');

        // Strip non-digits
        input.value = value;

        if (value.length === 0) {
            phoneError.style.display = 'none';
            input.dataset.phoneInvalid = 'false';
            return;
        }

        const isValid = /^09\d{9}$/.test(value);

        if (!isValid) {
            phoneError.textContent = 'Please enter a valid Philippine mobile number (e.g. 09XXXXXXXXX).';
            phoneError.style.display = 'block';
            input.dataset.phoneInvalid = 'true';
        } else {
            phoneError.style.display = 'none';
            input.dataset.phoneInvalid = 'false';
        }
    }

    // ===== DATE VALIDATION =====
    // Only allows dates 1 to 2 days from today (local browser date — no UTC offset)
    function getLocalDateOnly(date) {
        return new Date(date.getFullYear(), date.getMonth(), date.getDate());
    }

    function formatDate(d) {
        const yyyy = d.getFullYear();
        const mm = String(d.getMonth() + 1).padStart(2, '0');
        const dd = String(d.getDate()).padStart(2, '0');
        return `${yyyy}-${mm}-${dd}`;
    }

    function validateDate(input) {
        const dateError = document.getElementById('dateError');

        const localToday = getLocalDateOnly(new Date());
        const minDate = new Date(localToday);
        minDate.setDate(localToday.getDate() + 1);

        const maxDate = new Date(localToday);
        maxDate.setDate(localToday.getDate() + 2);

        // Parse selected date as local (split YYYY-MM-DD to avoid UTC shift)
        const [y, m, d] = input.value.split('-').map(Number);
        const selected = new Date(y, m - 1, d);

        if (selected < minDate || selected > maxDate) {
            const minStr = minDate.toLocaleDateString('en-PH', { month: 'long', day: 'numeric', year: 'numeric' });
            const maxStr = maxDate.toLocaleDateString('en-PH', { month: 'long', day: 'numeric', year: 'numeric' });
            dateError.textContent = `Please select a date between ${minStr} and ${maxStr}.`;
            dateError.style.display = 'block';
            input.dataset.dateInvalid = 'true';
        } else {
            dateError.style.display = 'none';
            input.dataset.dateInvalid = 'false';
        }
    }

    // Set min and max attributes on page load using local browser date
    document.addEventListener('DOMContentLoaded', function () {
        const dateInput = document.getElementById('reservationDate');
        if (!dateInput) return;

        const localToday = getLocalDateOnly(new Date());

        const minDate = new Date(localToday);
        minDate.setDate(localToday.getDate() + 1);

        const maxDate = new Date(localToday);
        maxDate.setDate(localToday.getDate() + 2);

        // Use manual format to avoid toISOString() UTC conversion
        dateInput.min = formatDate(minDate);
        dateInput.max = formatDate(maxDate);
    });

    // ===== EMAIL VALIDATION =====
    async function checkEmailExists() {
        const input = document.getElementById('reservationEmail');
        const errorLabel = document.getElementById('emailError');
        const email = (input.value || '').trim();

        if (!email) {
            errorLabel.style.display = 'none';
            input.dataset.emailInvalid = 'false';
            return;
        }

        try {
            const response = await fetch(`/User/CheckEmail?email=${encodeURIComponent(email)}`);
            if (!response.ok) {
                errorLabel.style.display = 'none';
                input.dataset.emailInvalid = 'false';
                return;
            }

            const data = await response.json();

            if (data.exists && data.isCustomer) {
                errorLabel.textContent = 'You already have a LuxeGroom account. Please log in to your Customer Portal to make a reservation.';
                errorLabel.style.display = 'block';
                input.dataset.emailInvalid = 'true';
            } else if (data.exists && !data.isCustomer) {
                errorLabel.textContent = 'This email is already in use. Please use a different email.';
                errorLabel.style.display = 'block';
                input.dataset.emailInvalid = 'true';
            } else {
                errorLabel.style.display = 'none';
                input.dataset.emailInvalid = 'false';
            }
        } catch {
            errorLabel.style.display = 'none';
            input.dataset.emailInvalid = 'false';
        }
    }

    // ===== OWNER NAME VALIDATION =====
    // Checks if OwnerName matches an existing Username in the Users table
    async function checkOwnerNameExists() {
        const input = document.getElementById('reservationOwnerName');
        const errorLabel = document.getElementById('ownerNameError');
        const ownerName = (input.value || '').trim();

        if (!ownerName) {
            errorLabel.style.display = 'none';
            input.dataset.ownerNameInvalid = 'false';
            return;
        }

        try {
            const response = await fetch(`/User/CheckOwnerName?ownerName=${encodeURIComponent(ownerName)}`);
            if (!response.ok) {
                errorLabel.style.display = 'none';
                input.dataset.ownerNameInvalid = 'false';
                return;
            }

            const data = await response.json();

            if (data.exists) {
                errorLabel.textContent = 'This name is already associated with a system account. Please use your full name as it appears on your ID.';
                errorLabel.style.display = 'block';
                input.dataset.ownerNameInvalid = 'true';
            } else {
                errorLabel.style.display = 'none';
                input.dataset.ownerNameInvalid = 'false';
            }
        } catch {
            errorLabel.style.display = 'none';
            input.dataset.ownerNameInvalid = 'false';
        }
    }

    // ===== FORM SUBMIT =====
    async function handleReservationSubmit(e) {
        e.preventDefault();

        // Block if owner name invalid
        const ownerNameInput = document.getElementById('reservationOwnerName');
        if (ownerNameInput && ownerNameInput.dataset.ownerNameInvalid === 'true') return;

        // Block if phone invalid
        const phoneInput = document.getElementById('reservationPhone');
        if (phoneInput && phoneInput.dataset.phoneInvalid === 'true') return;

        // Block if phone empty — trigger validation
        if (phoneInput && !/^09\d{9}$/.test(phoneInput.value)) {
            validatePhone(phoneInput);
            return;
        }

        // Block if date invalid
        const dateInput = document.getElementById('reservationDate');
        if (dateInput && dateInput.dataset.dateInvalid === 'true') return;

        // Re-validate date on submit in case user typed manually
        if (dateInput && dateInput.value) {
            validateDate(dateInput);
            if (dateInput.dataset.dateInvalid === 'true') return;
        }

        // Block if email invalid
        const emailInput = document.getElementById('reservationEmail');
        if (emailInput && emailInput.dataset.emailInvalid === 'true') return;

        const form = document.getElementById('reservationForm');
        const btn = document.getElementById('submitBtn');

        btn.disabled = true;
        btn.textContent = 'Submitting...';

        try {
            const formData = new FormData(form);
            const response = await fetch(form.action, {
                method: 'POST',
                body: formData
            });

            if (response.ok || response.redirected) {
                form.reset();
                closeModal();
                showSuccess();
            } else {
                alert('Something went wrong. Please try again.');
            }
        } catch (err) {
            form.reset();
            closeModal();
            showSuccess();
        } finally {
            btn.disabled = false;
            btn.textContent = 'Confirm Reservation';
        }
    }

    function showSuccess() {
        document.getElementById('successOverlay').classList.add('success--active');
        document.body.style.overflow = 'hidden';
    }

    function closeSuccess() {
        document.getElementById('successOverlay').classList.remove('success--active');
        document.body.style.overflow = '';
    }
</script>