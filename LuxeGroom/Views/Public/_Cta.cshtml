@*
 * _Cta.cshtml
 * Call-to-action / Concierge section.
 *@

@* Full-width CTA section anchored to the concierge nav link *@
<section class="cta-section" id="concierge">
    <div class="cta-box">

        @* Calendar icon above the heading *@
        <div class="cta-icon">
            <span class="material-symbols-outlined">event_available</span>
        </div>

        <h2>Reserve Your Session</h2>
        <p>Secure an exclusive appointment for your companion. Our concierge team will curate a bespoke grooming experience tailored to your pet's needs.</p>

        @* Book button opens the reservation modal overlay *@
        <button class="btn-outline-gold" onclick="openModal()">Book a Reservation</button>

    </div>
</section>
