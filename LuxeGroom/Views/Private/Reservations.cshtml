@*
 * Reservations.cshtml
 * Admin Reservation Management for LuxeGroom.
 * Lists all reservations with status badges and filter tabs.
 *@

@using LuxeGroom.Data.Generated
@model List<Reservation>

@{
    Layout = "/Views/Private/_Layout.cshtml";
    ViewBag.Title = "Reservations";
}

<link rel="stylesheet" href="~/css/private/reservations.css" />

@if (TempData["Success"] != null)
{
    <div class="toast toast--success" id="toastMsg">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="toast toast--error" id="toastMsg">@TempData["Error"]</div>
}

<header class="dashboard-header">
    <h1 class="welcome-title">Reservations</h1>
    <p class="welcome-subtitle">View and manage all customer reservation requests.</p>
</header>

<div class="activity-section">

    <div class="section-header">
        <h2 class="section-title">
            All Reservations
            <span class="res-count" id="visibleCount">(@Model.Count)</span>
        </h2>
    </div>

    <div class="search-wrapper">
        <span class="search-icon">🔍</span>
        <input type="text" id="searchInput" class="search-input"
               placeholder="Search owner, pet, email..."
               oninput="applyFilters()" />
    </div>

    <div class="res-tabs">
        <button class="res-tab active" onclick="setTab('all', this)">All</button>
        <button class="res-tab" onclick="setTab('Pending', this)">Pending</button>
        <button class="res-tab" onclick="setTab('Approved', this)">Approved</button>
        <button class="res-tab" onclick="setTab('Cancelled', this)">Cancelled</button>
    </div>

    <div class="no-results" id="noResults" style="display:none;">
        <p>No reservations found.</p>
    </div>

    <div class="list-scroll-wrapper">
        <div class="activity-card" id="reservationList">

            @if (Model.Count > 0)
            {
                foreach (var r in Model)
                {
                    string badgeClass = r.Status switch
                    {
                        "Pending" => "badge--pending",
                        "Approved" => "badge--confirmed",
                        "Cancelled" => "badge--cancelled",
                        _ => "badge--pending"
                    };

                    <div class="activity-item res-row"
                         data-status="@r.Status"
                         data-search="@(r.OwnerName.ToLower()) @(r.PetName.ToLower()) @(r.Email.ToLower()) @(r.GroomingStyle.ToLower())">

                        <div class="activity-icon">
                            <span class="material-symbols-outlined">pets</span>
                        </div>

                        <div class="activity-details" style="flex:1;">
                            <h4>
                                @r.OwnerName
                                <span style="color:#4b5563; font-weight:400;"> — </span>
                                @r.PetName
                            </h4>

                            <div class="res-meta">
                                <span>
                                    <span class="material-symbols-outlined">content_cut</span>
                                    @r.GroomingStyle
                                </span>
                                <span>
                                    <span class="material-symbols-outlined">pets</span>
                                    @r.PetSize
                                </span>
                                <span>
                                    <span class="material-symbols-outlined">call</span>
                                    @r.Phone
                                </span>
                                <span>
                                    <span class="material-symbols-outlined">mail</span>
                                    @r.Email
                                </span>
                            </div>

                            <p class="res-date">
                                <span class="material-symbols-outlined" style="font-size:13px;">calendar_month</span>
                                @r.ReservationDate.ToString("MMMM dd, yyyy")
                            </p>

                            <p class="res-id">@r.Id</p>
                        </div>

                        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px;">
                            <span class="status-badge @badgeClass">@r.Status</span>

                            @if (r.Status == "Pending")
                            {
                                <button class="btn-handle"
                                        onclick="openHandleModal(
                                                        '@r.Id',
                                                        '@Html.Raw(r.OwnerName.Replace("'", "\\'"))',
                                                        '@Html.Raw(r.PetName.Replace("'", "\\'"))',
                                                        '@r.PetSize',
                                                        '@Html.Raw(r.GroomingStyle.Replace("'", "\\'"))',
                                                        '@r.ReservationDate.ToString("yyyy-MM-dd")'
                                                    )">
                                    <span class="material-symbols-outlined">assignment</span>
                                    Handle Request
                                </button>
                            }
                        </div>

                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <p>No reservations yet.</p>
                </div>
            }

        </div>
    </div>

</div>

@* ── HANDLE REQUEST MODAL ── *@
<div class="modal-overlay" id="handleModal" style="display:none;" onclick="closeHandleModal(event)">
    <div class="modal-box">

        <div class="modal-header">
            <span class="material-symbols-outlined modal-icon">assignment_turned_in</span>
            <h3 class="modal-title">Handle Request</h3>
        </div>

        <div class="modal-body">
            <p class="modal-desc">Review and edit reservation details before accepting:</p>

            @* Read-only owner info *@
            <div class="modal-info-card">
                <p class="modal-info-label">Owner</p>
                <p class="modal-info-value" id="modalOwner">—</p>
            </div>

            @* Editable fields — sent to HandleAccept *@
            <form id="acceptForm" method="post" action="/Reservation/HandleAccept">
                @Html.AntiForgeryToken()
                <input type="hidden" id="acceptId" name="id" />

                @* Pet Name *@
                <div class="modal-field-group">
                    <label class="modal-field-label">Pet Name</label>
                    <input type="text" id="editPetName" name="petName"
                           class="modal-field-input" required />
                </div>

                @* Pet Size *@
                <div class="modal-field-group">
                    <label class="modal-field-label">Pet Size</label>
                    <select id="editPetSize" name="petSize"
                            class="modal-field-input" onchange="computeAmount()">
                        <option value="Small Dog">Small Dog</option>
                        <option value="Medium Dog">Medium Dog</option>
                        <option value="Large Dog">Large Dog</option>
                    </select>
                </div>

                @* Grooming Style *@
                <div class="modal-field-group">
                    <label class="modal-field-label">Grooming Style</label>
                    <select id="editGroomingStyle" name="groomingStyle"
                            class="modal-field-input" onchange="computeAmount()">
                        <option value="Bath & Brush">Bath &amp; Brush</option>
                        <option value="Full Groom">Full Groom</option>
                        <option value="Custom Cut">Custom Cut</option>
                    </select>
                </div>

                @* Reservation Date *@
                <div class="modal-field-group">
                    <label class="modal-field-label">Reservation Date</label>
                    <input type="date" id="editDate" name="reservationDate"
                           class="modal-field-input" required />
                </div>

                @* Amount Summary *@
                <div class="modal-amount-summary">
                    <div class="modal-amount-row">
                        <span>Total Amount</span>
                        <span id="totalAmount">₱0</span>
                    </div>
                    <div class="modal-amount-row modal-amount-downpayment">
                        <span>50% Down Payment Due</span>
                        <span id="downPayment">₱0</span>
                    </div>
                </div>

                <div class="modal-actions">
                    <button type="submit" class="btn-modal btn-accept">
                        <span class="material-symbols-outlined">check_circle</span>
                        Accept
                    </button>
                    <button type="button" class="btn-modal btn-cancel-req"
                            onclick="submitCancel()">
                        <span class="material-symbols-outlined">cancel</span>
                        Cancel Request
                    </button>
                    <button type="button" class="btn-modal btn-dismiss" onclick="closeModal()">
                        Dismiss
                    </button>
                </div>

            </form>
        </div>

    </div>
</div>

@* Cancel form — separate, no editable fields needed *@
<form id="cancelForm" method="post" action="/Reservation/HandleCancel" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="cancelId" name="id" />
</form>

<script>
    // ── Pricing table (must match backend) ──
    const prices = {
        'Bath & Brush': { 'Small Dog': 300, 'Medium Dog': 600, 'Large Dog': 750 },
        'Full Groom':   { 'Small Dog': 900, 'Medium Dog': 1000, 'Large Dog': 1250 },
        'Custom Cut':   { 'Small Dog': 1200, 'Medium Dog': 1300, 'Large Dog': 1500 }
    };

    let activeTab = 'all';

    function computeAmount() {
        const style = document.getElementById('editGroomingStyle').value;
        const size  = document.getElementById('editPetSize').value;
        const total = (prices[style] && prices[style][size]) ? prices[style][size] : 0;
        const down  = Math.round(total * 0.5);
        document.getElementById('totalAmount').textContent  = `₱${total.toLocaleString()}`;
        document.getElementById('downPayment').textContent  = `₱${down.toLocaleString()}`;
    }

    function openHandleModal(id, owner, pet, petSize, groomingStyle, date) {
        document.getElementById('acceptId').value           = id;
        document.getElementById('modalOwner').textContent   = owner;
        document.getElementById('editPetName').value        = pet;
        document.getElementById('editPetSize').value        = petSize;
        document.getElementById('editGroomingStyle').value  = groomingStyle;
        document.getElementById('editDate').value           = date;
        computeAmount();
        document.getElementById('handleModal').style.display = 'flex';
    }

    function closeHandleModal(event) {
        if (event.target.id === 'handleModal') closeModal();
    }

    function closeModal() {
        document.getElementById('handleModal').style.display = 'none';
    }

    function submitCancel() {
        document.getElementById('cancelId').value = document.getElementById('acceptId').value;
        document.getElementById('cancelForm').submit();
    }

    function setTab(status, btn) {
        activeTab = status;
        document.querySelectorAll('.res-tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('searchInput').value = '';
        applyFilters();
    }

    function applyFilters() {
        const query = document.getElementById('searchInput').value.toLowerCase().trim();
        const rows  = document.querySelectorAll('.res-row');
        let visible = 0;

        rows.forEach(row => {
            const matchStatus = activeTab === 'all' || row.dataset.status === activeTab;
            const matchSearch = !query || row.dataset.search.includes(query);
            const show = matchStatus && matchSearch;
            row.style.display = show ? 'flex' : 'none';
            if (show) visible++;
        });

        document.getElementById('visibleCount').textContent = `(${visible})`;
        document.getElementById('noResults').style.display  = visible === 0 ? 'block' : 'none';
    }

    const toast = document.getElementById('toastMsg');
    if (toast) {
        setTimeout(() => {
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 400);
        }, 3000);
    }
</script>