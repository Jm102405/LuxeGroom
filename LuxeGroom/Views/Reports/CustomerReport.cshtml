@*
 * CustomerReport.cshtml
 * Displays a filterable table of all customers for admin reporting.
 * Filters: Search by Name, Search by Email
 * Updated in Thread3.1: Simplified print view, removed non-existent Id and DateRegistered columns.
 *@

@using LuxeGroom.Data.Generated

@{
    Layout = "/Views/Private/_Layout.cshtml";
    ViewBag.Title = "Customer Report";
}

<link rel="stylesheet" href="~/css/reports/reports.css" />

<div class="report-container">

    <!-- Page header with title and print button -->
    <div class="report-header">
        <h1 class="report-title">Customer Report</h1>
        <button onclick="window.print()" class="btn-print">🖨️ Print Report</button>
    </div>

    <!-- Filter Form: search by name and email, submitted via GET so filters appear in URL -->
    <form method="get" class="filter-form">
        <div class="filter-group">
            <label for="dateFrom">Date From</label>
            <input type="date" id="dateFrom" name="dateFrom" value="@ViewBag.DateFrom" />
        </div>

        <div class="filter-group">
            <label for="dateTo">Date To</label>
            <input type="date" id="dateTo" name="dateTo" value="@ViewBag.DateTo" />
        </div>

        <button type="submit" class="btn-filter">Apply Filter</button>
    </form>

    <!-- Reset link clears all filters by navigating to the base URL -->
    <a href="/Reports/CustomerReport" style="color: #94a3b8; font-size: 14px; margin-top: 10px; display: inline-block;">Reset</a>

    <!-- Report Table: shows all customers matching the current filters -->
    <div class="report-table-wrapper">
        <table class="report-table">
            <thead>
                <tr>
                    <th>First Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th class="print-hide">Username</th> @* Hidden on print — internal data only *@
                </tr>
            </thead>
            <tbody>
                @* Render a row per customer if results exist, otherwise show empty state *@
                @if (ViewBag.Customers != null && ((List<Customer>)ViewBag.Customers).Count > 0)
                {
                    foreach (var c in (List<Customer>)ViewBag.Customers)
                    {
                        <tr>
                            <td>@c.Firstname</td>
                            <td>@c.Email</td>
                            <td>@c.Phone</td>
                            <td class="print-hide">@c.Username</td>
                        </tr>
                    }
                }
                else
                {
                    @* No results found — show a centered empty state message *@
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 30px; color: #94a3b8;">
                            No customers found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Footer showing total number of records returned by the current filter -->
    <p class="report-footer">Total Records: <strong>@(ViewBag.Customers?.Count ?? 0)</strong></p>

</div>