@*
 * ReservationReport.cshtml
 * Displays a filterable table of all reservations for admin reporting.
 * Filters: Date Range, Status
 * Updated in Thread3.1: Status value fixed to Cancelled (double L) to match database.
 *@

@using LuxeGroom.Data.Generated

@{
    Layout = "/Views/Private/_Layout.cshtml";
    ViewBag.Title = "Reservation Report";
}

<link rel="stylesheet" href="~/css/reports/reports.css" />

<div class="report-container">

    <!-- Page header with title and print button -->
    <div class="report-header">
        <h1 class="report-title">Reservation Report</h1>
        <button onclick="window.print()" class="btn-print">🖨️ Print Report</button>
    </div>

    <!-- Filter Form: submitted via GET so filters persist in the URL -->
    <form method="get" class="filter-form">

        <!-- Date range filters — both optional, can be used independently -->
        <div class="filter-group">
            <label for="dateFrom">Date From</label>
            <input type="date" id="dateFrom" name="dateFrom" value="@ViewBag.DateFrom" />
        </div>

        <div class="filter-group">
            <label for="dateTo">Date To</label>
            <input type="date" id="dateTo" name="dateTo" value="@ViewBag.DateTo" />
        </div>

        <!-- Status filter: value must match exact DB values (Pending, Approved, Cancelled with double L) -->
        <div class="filter-group">
            <label for="status">Status</label>
            <select id="status" name="status">
                <option value="">All</option>
                <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending</option>
                <option value="Approved" selected="@(ViewBag.Status == "Approved")">Approved</option>
                <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Cancelled</option>
            </select>
        </div>

        <button type="submit" class="btn-filter">Apply Filter</button>
    </form>

    <!-- Reset link clears all filters by navigating to the base URL -->
    <a href="/Reports/ReservationReport" style="color: #94a3b8; font-size: 14px; margin-top: 10px; display: inline-block;">Reset</a>

    <!-- Report Table: shows all reservations matching the current filters -->
    <div class="report-table-wrapper">
        <table class="report-table">
            <thead>
                <tr>
                    <th class="print-hide">Reservation ID</th> @* Hidden on print — internal reference only *@
                    <th>Owner Name</th>
                    <th>Pet Name</th>
                    <th>Grooming Style</th>
                    <th class="print-hide">Phone</th> @* Hidden on print — personal data *@
                    <th>Date</th>
                    <th class="print-hide">Status</th> @* Hidden on print — operational data only *@
                </tr>
            </thead>
            <tbody>
                @* Render a row per reservation if results exist, otherwise show empty state *@
                @if (ViewBag.Reservations != null && ((List<Reservation>)ViewBag.Reservations).Count > 0)
                {
                    foreach (var r in (List<Reservation>)ViewBag.Reservations)
                    {
                        <tr>
                            <td class="print-hide">@r.Id</td>
                            <td>@r.OwnerName</td>
                            <td>@r.PetName</td>
                            <td>@r.GroomingStyle</td>
                            <td class="print-hide">@r.Phone</td>
                            <td>@r.ReservationDate.ToString("MMM dd, yyyy")</td>
                            <td class="print-hide">
                                @* Dynamic CSS class: status-pending / status-approved / status-cancelled *@
                                <span class="status-badge status-@r.Status.ToLower()">@r.Status</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    @* No results — show centered empty state message *@
                    <tr>
                        <td colspan="7" style="text-align: center; padding: 30px; color: #94a3b8;">
                            No reservations found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Footer showing total number of records returned by the current filter -->
    <p class="report-footer">Total Records: <strong>@(ViewBag.Reservations?.Count ?? 0)</strong></p>

</div>